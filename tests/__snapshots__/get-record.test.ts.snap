    >
      
          
      <dc:title
        xml:lang="de"
      >
        GEOFAST 1:50.000, Blatt 53 – Amstetten, Stand 2019
      </dc:title>
      
          
      <dc:title
        xml:lang="en"
      >
        GEOFAST 1:50,000. Map Nr. 53 – Amstetten, stand 2019
      </dc:title>
      
          
      <dc:title
        xml:lang="de"
      >
        Zusammenstellung ausgewählter Archivunterlagen der Geologischen
            Bundesanstalt
      </dc:title>
      
          
      <dc:creator>
        Linner, Manfred
      </dc:creator>
      
          
