{
  "name": "oai-pmh-2-js",
  "version": "0.11.0",
  "author": "Levente Fodor",
  "license": "MIT",
  "description": "OAI-PMH Version 2.0 API ECMAScript client.",
  "keywords": [
    "OAI-PMH",
    "oaipmh",
    "oai",
    "metadata",
    "harvest",
    "protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flevi29/oai-pmh-2-js.git"
  },
  "bugs": {
    "url": "https://github.com/flevi29/oai-pmh-2-js/issues"
  },
  "homepage": "https://github.com/flevi29/oai-pmh-2-js#readme",
  "type": "module",
  "files": [
    "./src/",
    "./dist/",
    "./LICENSE",
    "./package.json"
  ],
  "exports": {
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  },
  "imports": {
    "#src/*": "./src/*.ts"
  },
  "sideEffects": false,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "create-jsr": "node scripts/create-jsr-json.ts",
    "test": "vitest run",
    "check": "tsc",
    "format": "prettier --write .",
    "lint": "prettier --check . && oxlint"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "@vitest/coverage-v8": "4.1.3",
    "jsr": "0.14.3",
    "linkedom": "0.18.12",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "prettier": "3.8.1",
    "prettier-plugin-jsdoc": "1.8.0",
    "prettier-plugin-svelte": "3.5.1",
    "typescript": "6.0.2",
    "vite": "8.0.7",
    "vitest": "4.1.3"
  },
  "packageManager": "pnpm@10.33.0"
}
